generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ServerStatus {
  id               String   @id @default(uuid())
  serverName       String   @unique
  domain           String?
  ip               String?
  os               String?
  installDate      String?
  installedKBs     String?
  rebootDate       String?
  errorDescription String?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model SyncRun {
  id       String        @id @default(uuid())
  syncedAt DateTime      @default(now())
  total    Int           @default(0)
  success  Int           @default(0)
  errors   Int           @default(0)
  noData   Int           @default(0)
  records  SyncHistory[]
}

model SyncHistory {
  id               String   @id @default(uuid())
  syncRunId        String
  syncRun          SyncRun  @relation(fields: [syncRunId], references: [id])
  serverName       String
  domain           String?
  ip               String?
  os               String?
  installDate      String?
  installedKBs     String?
  rebootDate       String?
  errorDescription String?
  status           String
  createdAt        DateTime @default(now())

  @@index([syncRunId])
  @@index([serverName])
  @@index([status])
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}
